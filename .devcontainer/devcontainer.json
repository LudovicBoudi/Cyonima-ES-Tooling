{
    "name": "Cyonima-ES-Tools",
    "image": "mcr.microsoft.com/devcontainers/python:3.12",
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {}
    },
    "forwardPorts": [8080],
    "postCreateCommand": "pip install -r requirements.txt && python manage.py migrate && echo '=== Prêt ! Lancez : python manage.py runserver 0.0.0.0:8080 ==='",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "batisteo.vscode-django",
                "bradlc.vscode-tailwindcss"
            ]
        }
    }
}
